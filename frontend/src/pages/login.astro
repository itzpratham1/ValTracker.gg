---
import Layout from '../layouts/Layout.astro';
import LookupView from '../components/tracker/LookupView.svelte';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "ValTracker Lookup",
  "description": "Look up any Valorant player profile, track match statistics, and view analytical insights instantly."
};
---

<Layout
  title="ValTracker — Look Up a Player"
  description="Look up any Valorant player profile. No account or login required—just enter a Riot ID and tag."
  structuredData={structuredData}
>
  <LookupView client:only="svelte" />
</Layout>
