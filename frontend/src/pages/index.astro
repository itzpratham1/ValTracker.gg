---
import Layout from '../layouts/Layout.astro';
import '../styles/landing.css';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "ValTracker",
  "url": "https://valtracker.live",
  "description": "Free Valorant stats tracker with AI coaching, live OBS overlays, and real-time match analysis.",
  "applicationCategory": "GameApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "featureList": ["Stats Tracker", "AI Coaching", "OBS Overlays", "VCT Esports Hub", "Meta Comp Architect", "Performance Lab"],
  "screenshot": "https://valtracker.live/stats_tracker_card.webp"
};
---

<Layout
  title="ValTracker — Free Valorant Stats Tracker, AI Coaching & OBS Overlays"
  description="ValTracker is the free Valorant stats tracker with AI coaching, live OBS overlays, and real-time match analysis. No account required. Track your K/D, ACS, win rate and rank progression instantly."
  structuredData={structuredData}
>
  

<!-- ════════════════════════════════
     NAVBAR
════════════════════════════════ -->
<nav class="nav" id="main-nav" role="navigation" aria-label="Main navigation">
  <a href="/" class="nav-logo" aria-label="ValTracker Home">
    <img src="/logo.png" class="nav-logo-img" alt="ValTracker Logo" onerror="this.style.display='none'">
    <span>ValTracker</span>
  </a>

  <div class="nav-actions">
    <a href="/login" class="btn-red" id="nav-track-btn">Track Now →</a>
  </div>

  <button class="nav-mobile-toggle" id="nav-mobile-toggle" aria-label="Toggle navigation menu" aria-expanded="false">
    <span class="nav-hamburger-line"></span>
    <span class="nav-hamburger-line"></span>
    <span class="nav-hamburger-line"></span>
  </button>

  <div class="nav-mobile-menu" id="nav-mobile-menu" role="menu">
    <a href="/login" class="nav-mobile-link" role="menuitem">Tracker</a>
    <a href="/app#esports" class="nav-mobile-link" role="menuitem">VCT Esports</a>
    <a href="/app#skins" class="nav-mobile-link" role="menuitem">Skins Store</a>
    <a href="/comp" class="nav-mobile-link" role="menuitem">Meta Comp</a>
    <a href="/app#overlay" class="nav-mobile-link" role="menuitem">OBS Overlay</a>
  </div>
</nav>

<!-- ════════════════════════════════
     HERO SECTION
════════════════════════════════ -->
<section class="hero" id="hero" aria-labelledby="hero-headline">
  <div class="hero-bg">
    <div class="hero-grid"></div>
    <div class="hero-glow"></div>
    <div class="hero-glow-2"></div>
    <div class="glow-orb orb-1"></div>
    <div class="glow-orb orb-2"></div>
    <div class="glow-orb orb-3"></div>
    <canvas id="hero-canvas" aria-hidden="true"></canvas>
  </div>

  <div class="hero-content">
    <div class="hero-eyebrow" aria-label="Free Valorant stats tracker">
      Free forever · No account needed
    </div>

    <h1 class="hero-headline" id="hero-headline">
      <span class="reveal-line-wrap">
        <span class="reveal-line line-1">Stop Guessing.</span>
      </span>
      <span class="reveal-line-wrap">
        <span class="reveal-line line-2 accent-line">Start Climbing.</span>
      </span>
    </h1>

    <p class="hero-sub">
      Real-time Valorant stats, AI coaching, and live OBS overlays.<br>
      Free. Always.
    </p>

    <div class="hero-cta-wrap">
      <a href="/login" class="btn-hero" id="hero-cta-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="5 12 12 5 19 12"></polyline><polyline points="5 19 12 12 19 19"></polyline></svg>
        Track Your Stats
      </a>
      <p class="hero-note">No account needed. Just your Riot ID.</p>
    </div>
  </div>

  <!-- Animated Stats Dashboard Mockup -->
  <div class="hero-mockup-wrap">
    <div class="hero-browser-frame">
      <div class="browser-titlebar">
        <div class="browser-dots">
          <div class="browser-dot red"></div>
          <div class="browser-dot amber"></div>
          <div class="browser-dot green"></div>
        </div>
        <div class="browser-url-bar">
          <svg class="url-lock" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
          <span id="browser-url-text">valtracker.live/app/stats</span>
        </div>
      </div>

      <!-- Tabs to toggle real screenshots -->
      <div class="browser-tabs" role="tablist" aria-label="Mockup views">
        <button class="browser-tab active" role="tab" aria-selected="true" data-target="hero-stats-tab">Stats Dashboard</button>
        <button class="browser-tab" role="tab" aria-selected="false" data-target="hero-ai-tab">ValBot AI Coach</button>
      </div>

      <div class="browser-body" style="padding: 0; background: #0c0c0f; position: relative;">
        <img id="hero-stats-img" src="/stats_tracker_card.webp" alt="Real ValTracker stats dashboard showing live player statistics and match list" loading="eager" style="width: 100%; height: auto; display: block;">
        <img id="hero-ai-img" src="/Val_bot_analysis.webp" alt="Real ValBot AI coach dashboard showing post-match recommendations" loading="lazy" style="width: 100%; height: auto; display: none;">
      </div>
    </div>
  </div>
</section>

<div class="section-divider" role="separator"></div>

<!-- ════════════════════════════════
     TICKER BAR
════════════════════════════════ -->
<div class="ticker-bar" role="marquee" aria-label="ValTracker features">
  <div class="ticker-track">
    <!-- First copy -->
    <div class="ticker-item"><span class="ticker-dot" aria-hidden="true">✦</span>530+ Matches Cached</div>
    <div class="ticker-item"><span class="ticker-dot" aria-hidden="true">✦</span>Free Forever</div>
    <div class="ticker-item"><span class="ticker-dot" aria-hidden="true">✦</span>AI-Powered Coaching</div>
    <div class="ticker-item"><span class="ticker-dot" aria-hidden="true">✦</span>OBS Ready</div>
    <div class="ticker-item"><span class="ticker-dot" aria-hidden="true">✦</span>VCT Live Coverage</div>
    <div class="ticker-item"><span class="ticker-dot" aria-hidden="true">✦</span>No Login Required</div>
    <div class="ticker-item"><span class="ticker-dot" aria-hidden="true">✦</span>Real-Time Stats</div>
    <div class="ticker-item"><span class="ticker-dot" aria-hidden="true">✦</span>Meta Comp Architect</div>
    <!-- Duplicate for seamless loop -->
    <div class="ticker-item"><span class="ticker-dot" aria-hidden="true">✦</span>530+ Matches Cached</div>
    <div class="ticker-item"><span class="ticker-dot" aria-hidden="true">✦</span>Free Forever</div>
    <div class="ticker-item"><span class="ticker-dot" aria-hidden="true">✦</span>AI-Powered Coaching</div>
    <div class="ticker-item"><span class="ticker-dot" aria-hidden="true">✦</span>OBS Ready</div>
    <div class="ticker-item"><span class="ticker-dot" aria-hidden="true">✦</span>VCT Live Coverage</div>
    <div class="ticker-item"><span class="ticker-dot" aria-hidden="true">✦</span>No Login Required</div>
    <div class="ticker-item"><span class="ticker-dot" aria-hidden="true">✦</span>Real-Time Stats</div>
    <div class="ticker-item"><span class="ticker-dot" aria-hidden="true">✦</span>Meta Comp Architect</div>
  </div>
</div>


<!-- ════════════════════════════════
     FEATURES BENTO GRID
════════════════════════════════ -->
<section class="section" id="features" aria-labelledby="features-title">
  <div class="section-inner">
    <div class="section-label reveal">
      <span class="section-eyebrow">Features</span>
      <div class="section-label-line"></div>
    </div>

    <div style="max-width: 640px; margin-bottom: 56px;">
      <h2 class="section-title reveal" id="features-title">Everything You Need<br>To Rank Up</h2>
    </div>

    <div class="bento-grid" id="bento-grid" aria-label="Feature cards">

      <!-- ROW 1: Full-width Stats Tracker -->
      <article class="bento-card span-12 large-card" aria-labelledby="card-tracker-title">
        <span class="card-tag">Core Feature</span>
        <h3 class="bento-title" id="card-tracker-title">Stats Tracker</h3>
        <p class="bento-body">K/D, ACS, headshot %, win rate, RR progression — every metric that matters for your rank.</p>
        <div class="card-img-frame">
          <img src="/stats_tracker_card.webp" alt="ValTracker stats dashboard showing K/D, ACS, headshot %, win rate and RR progression" loading="lazy" decoding="async" fetchpriority="low" width="800" height="200">
        </div>
      </article>

      <!-- ROW 2: Three equal columns -->
      <article class="bento-card span-4 red-glow" aria-labelledby="card-ai-title">
        <span class="card-tag red-tag">AI Powered</span>
        <h3 class="bento-title" id="card-ai-title">ValBot AI Coach</h3>
        <p class="bento-body">Analyzes your matches to provide combat reviews, fatigue indicators, tilt diagnostics, and customized roadmaps to rank up.</p>
        <div class="card-img-frame">
          <img src="/Val_bot_analysis.webp" alt="ValBot AI coach verdict and performance analysis" loading="lazy" decoding="async" fetchpriority="low" width="600" height="160">
        </div>
      </article>

      <article class="bento-card span-4" aria-labelledby="card-deep-title">
        <span class="card-tag">Deep Analysis</span>
        <h3 class="bento-title" id="card-deep-title">Self-Analysis Diagnostics</h3>
        <p class="bento-body">Attack vs Defense win rates, agent-map fit, consistency trends. Your tactical blueprint.</p>
        <div class="card-img-frame">
          <img src="/deep_analysis.gif" alt="Deep analysis diagnostics showing attack vs defense win rates and agent-map fit" loading="lazy" decoding="async" fetchpriority="low" width="600" height="160">
        </div>
      </article>

      <article class="bento-card span-4" aria-labelledby="card-lab-title">
        <span class="card-tag">Performance Lab</span>
        <h3 class="bento-title" id="card-lab-title">Performance Diagnostics</h3>
        <p class="bento-body">Quantify your session trends with automatic tilt alerts, fatigue scoring, and performance calendar tracking.</p>
        <div class="card-img-frame">
          <img src="/perf_lab.gif" alt="Performance lab showing tilt detection and fatigue scoring charts" loading="lazy" decoding="async" fetchpriority="low" width="600" height="160">
        </div>
      </article>

      <!-- ROW 3: Three equal columns -->
      <article class="bento-card span-4" aria-labelledby="card-obs-title">
        <span class="card-tag">Unique</span>
        <h3 class="bento-title" id="card-obs-title">OBS Stream Overlay</h3>
        <p class="bento-body">Show live rank and stats on stream. One URL into OBS Browser Source. Done.</p>
        <div class="card-img-frame contain-fit">
          <img src="/obs_overlay.webp" alt="OBS stream overlay preview showing live rank and stats" loading="lazy" decoding="async" fetchpriority="low" width="600" height="140">
        </div>
      </article>

      <a href="/comp" class="bento-card span-4 bento-link-card" aria-labelledby="card-meta-title">
        <span class="card-tag">Strategy</span>
        <h3 class="bento-title" id="card-meta-title">Meta Comp Architect</h3>
        <p class="bento-body">Draft 5-agent team comps and check synergies automatically validated against active VCT tournament picks.</p>
        <div class="card-img-frame">
          <img src="/meta_comp.webp" alt="Meta comp architect showing 5-agent draft and VCT meta evaluation" loading="lazy" decoding="async" fetchpriority="low" width="600" height="140">
        </div>
      </a>

      <article class="bento-card span-4" aria-labelledby="card-store-title">
        <span class="card-tag">Browse</span>
        <h3 class="bento-title" id="card-store-title">Skins Store</h3>
        <p class="bento-body">Browse all Valorant skins, VP pricing, chromas and finisher previews.</p>
        <div class="card-img-frame">
          <img src="/skin_store.webp" alt="Valorant skins store with VP pricing and chroma previews" loading="lazy" decoding="async" fetchpriority="low" width="600" height="140">
        </div>
      </article>

      <!-- ROW 4: Full-width VCT Esports -->
      <article class="bento-card span-12 large-card" aria-labelledby="card-vct-title">
        <span class="card-tag">Live</span>
        <h3 class="bento-title" id="card-vct-title">VCT Esports Hub</h3>
        <p class="bento-body">Track live VCT tournament brackets, match schedules, standings, and professional player stats updated in real-time.</p>
        <div class="card-img-frame">
          <img src="/VCT_Esports.webp" alt="VCT Esports hub showing active brackets, match cards and live scores" loading="lazy" decoding="async" fetchpriority="low" width="800" height="160">
        </div>
      </article>

    </div>
  </div>
</section>

<div class="section-divider" role="separator"></div>

<!-- ════════════════════════════════
     NOT JUST A TRACKER SECTION
════════════════════════════════ -->
<section class="section njt-section" id="not-just-a-tracker" aria-labelledby="njt-title">
  <div class="section-inner">
    <div class="njt-header">
      <div class="section-label reveal" style="justify-content: center; margin-bottom: 24px;">
        <span class="section-eyebrow"><span class="live-dot"></span>Not Your Ordinary Tracker</span>
      </div>
      <h2 class="section-title reveal" id="njt-title" style="margin-bottom: 16px;">Every other tracker shows you numbers.<br><span style="color: var(--accent);">We show you why.</span></h2>
      <p class="section-subtitle reveal" style="margin-left: auto; margin-right: auto; max-width: 680px;">tracker.gg tells you your K/D. Others show your rank. ValTracker tells you exactly what's holding your rank back — and what to fix, every session.</p>
    </div>

    <div class="njt-grid" role="list" aria-label="ValTracker exclusive vs standard features">
      <!-- Exclusive Cards -->
      <article class="njt-card exclusive reveal" role="listitem">
        <span class="njt-badge">Only ValTracker</span>
        <div class="njt-icon" aria-hidden="true">🤖</div>
        <h3 class="njt-card-title">ValBot AI Coach</h3>
        <p class="njt-card-desc">Get a personalized coaching verdict after every session. Pinpoints exact weak spots and maps out a session roadmap.</p>
      </article>

      <article class="njt-card exclusive reveal" role="listitem">
        <span class="njt-badge">Only ValTracker</span>
        <div class="njt-icon" aria-hidden="true">🧪</div>
        <h3 class="njt-card-title">Performance Lab</h3>
        <p class="njt-card-desc">Quantify your mental game. Detect tilt, monitor fatigue buildup, track performance decay, and find best hours to queue.</p>
      </article>

      <article class="njt-card exclusive reveal" role="listitem">
        <span class="njt-badge">Only ValTracker</span>
        <div class="njt-icon" aria-hidden="true">📺</div>
        <h3 class="njt-card-title">Free OBS Overlays</h3>
        <p class="njt-card-desc">Show live rank and match stats on stream. Zero setup—simply copy and paste a single browser source URL into OBS.</p>
      </article>

      <!-- Standard Cards -->
      <article class="njt-card reveal" role="listitem">
        <div class="njt-icon" aria-hidden="true">📊</div>
        <h3 class="njt-card-title">Deep Stats Tracker</h3>
        <p class="njt-card-desc">Analyze K/D, ACS, headshot %, win rates, and RR progression instantly. Fully operational with no account login required.</p>
      </article>

      <a href="/comp" class="njt-card reveal njt-card-link" role="listitem">
        <div class="njt-icon" aria-hidden="true">📐</div>
        <h3 class="njt-card-title">Meta Comp Architect</h3>
        <p class="njt-card-desc">Draft 5-agent team comps and evaluate synergies automatically against active VCT pro tournament picks and win rates.</p>
      </a>

      <article class="njt-card reveal" role="listitem">
        <div class="njt-icon" aria-hidden="true">🏆</div>
        <h3 class="njt-card-title">VCT Esports Hub</h3>
        <p class="njt-card-desc">Follow pro tournament rosters, schedules, and live brackets. Get instant matches alerts and VCT point updates.</p>
      </article>
    </div>

    <!-- Comparison Table -->
    <div class="njt-table-container reveal">
      <table class="njt-table" aria-label="Feature comparison table">
        <thead>
          <tr>
            <th scope="col">Feature / Capabilities</th>
            <th scope="col" class="highlight-col">ValTracker</th>
            <th scope="col">tracker.gg</th>
            <th scope="col">Others</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Real-time stats & match history</td>
            <td class="highlight-col"><span class="njt-check" aria-label="Yes">✓</span></td>
            <td><span class="njt-check" aria-label="Yes">✓</span></td>
            <td><span class="njt-check" aria-label="Yes">✓</span></td>
          </tr>
          <tr>
            <td>No login required</td>
            <td class="highlight-col"><span class="njt-check" aria-label="Yes">✓</span></td>
            <td><span class="njt-check" aria-label="Yes">✓</span></td>
            <td><span class="njt-cross" aria-label="Varies">Varies</span></td>
          </tr>
          <tr>
            <td>AI coaching after every session</td>
            <td class="highlight-col"><span class="njt-check" aria-label="Yes">✓</span></td>
            <td><span class="njt-cross" aria-label="No">✗</span></td>
            <td><span class="njt-cross" aria-label="No">✗</span></td>
          </tr>
          <tr>
            <td>Tilt & fatigue detection</td>
            <td class="highlight-col"><span class="njt-check" aria-label="Yes">✓</span></td>
            <td><span class="njt-cross" aria-label="No">✗</span></td>
            <td><span class="njt-cross" aria-label="No">✗</span></td>
          </tr>
          <tr>
            <td>OBS stream overlay</td>
            <td class="highlight-col"><span class="njt-check" aria-label="Yes">✓</span></td>
            <td><span class="njt-check" aria-label="Yes">✓</span></td>
            <td><span class="njt-cross" aria-label="No">✗</span></td>
          </tr>
          <tr>
            <td>Single URL paste → OBS, zero setup</td>
            <td class="highlight-col"><span class="njt-check" aria-label="Yes">✓</span></td>
            <td><span class="njt-cross" aria-label="No">✗</span></td>
            <td><span class="njt-cross" aria-label="No">✗</span></td>
          </tr>
          <tr>
            <td>Meta comp architect</td>
            <td class="highlight-col"><span class="njt-check" aria-label="Yes">✓</span></td>
            <td><span class="njt-cross" aria-label="No">✗</span></td>
            <td><span class="njt-cross" aria-label="No">✗</span></td>
          </tr>
          <tr>
            <td>100% free, no premium tier</td>
            <td class="highlight-col"><span class="njt-check" aria-label="Yes">✓</span></td>
            <td><span class="njt-cross" style="opacity: 0.85;" aria-label="Ads or 3 dollars per month">Ads / $3 p/m</span></td>
            <td><span class="njt-cross" style="opacity: 0.85;" aria-label="Freemium">Freemium</span></td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- CTA Strip -->
    <div class="njt-cta reveal">
      <div class="njt-cta-btn">
        <a href="/login" class="btn-hero" id="njt-cta-btn" style="display:inline-flex;">Start Tracking Free →</a>
      </div>
      <p class="njt-cta-label">No sign-up. Just your Riot ID.</p>
    </div>
  </div>
</section>

<div class="section-divider" role="separator"></div>

<!-- ════════════════════════════════
     SOCIAL PROOF BAR
════════════════════════════════ -->
<div class="stats-bar" id="stats-bar" role="region" aria-label="ValTracker statistics">
  <div class="stats-bar-inner">
    <div class="stat-counter">
      <span class="counter-num" id="counter-matches" aria-live="polite">0+</span>
      <div class="counter-label">Matches Analysed</div>
    </div>
    <div class="stat-counter">
      <span class="counter-num" id="counter-features" aria-live="polite">0</span>
      <div class="counter-label">Powerful Features & More</div>
    </div>
    <div class="stat-counter">
      <span class="counter-num" id="counter-free" aria-live="polite">0%</span>
      <div class="counter-label">Free Forever</div>
    </div>
  </div>
</div>

<div class="section-divider" role="separator"></div>

<!-- ════════════════════════════════
     HOW IT WORKS
════════════════════════════════ -->
<section class="section" id="how-it-works" aria-labelledby="how-title">
  <div class="section-inner">
    <div class="section-label reveal">
      <span class="section-eyebrow">How It Works</span>
      <div class="section-label-line"></div>
    </div>
    <div style="text-align:center; margin-bottom:72px;">
      <h2 class="section-title reveal" id="how-title" style="display:inline-block;">Three Steps To Your Stats</h2>
    </div>

    <div class="steps-wrap" role="list" aria-label="Three steps to get started">
      <div class="step-item" role="listitem">
        <div class="step-num-wrap" aria-hidden="true">
          <span class="step-num">01</span>
        </div>
        <h3 class="step-title">Enter Your Riot ID</h3>
        <p class="step-body">Type your in-game name and tag. No account. No login. Just paste your Riot ID and go.</p>
      </div>
      <div class="step-item" role="listitem">
        <div class="step-num-wrap" aria-hidden="true">
          <span class="step-num">02</span>
        </div>
        <h3 class="step-title">Fetch Your Stats</h3>
        <p class="step-body">ValTracker pulls your last 20 matches in 5–10 seconds and compiles every metric that matters.</p>
      </div>
      <div class="step-item" role="listitem">
        <div class="step-num-wrap" aria-hidden="true">
          <span class="step-num">03</span>
        </div>
        <h3 class="step-title">Climb Faster</h3>
        <p class="step-body">Use ValBot AI, Deep Analysis, and Performance Lab to identify and fix your exact weak spots.</p>
      </div>
    </div>
  </div>
</section>

<div class="section-divider" role="separator"></div>

<!-- ════════════════════════════════
     FINAL CTA
════════════════════════════════ -->
<section class="final-cta-section" id="final-cta" aria-labelledby="final-cta-title">
  <div class="final-cta-card reveal">
    <h2 id="final-cta-title">Ready To See<br>Your Real Stats?</h2>
    <p>Join thousands of Valorant players already using ValTracker to rank up faster with real data.</p>
    <a href="/login" class="btn-hero" id="final-cta-btn" style="display:inline-flex;">→ Track Now — It's Free</a>
    <p class="final-cta-note">
      No sign-up required
      <span aria-hidden="true">·</span>
      Free forever
      <span aria-hidden="true">·</span>
      Built by a Valorant player
    </p>
  </div>
</section>

<!-- ════════════════════════════════
     FOOTER
════════════════════════════════ -->
<footer role="contentinfo">
  <div class="footer-main">
    <div>
      <div class="footer-logo">
        <img src="/logo.png" class="footer-logo-img" alt="ValTracker Logo" onerror="this.style.display='none'">
        <span>ValTracker</span>
      </div>
      <div class="footer-by">Built by Pratham</div>
    </div>

    <nav class="footer-nav" aria-label="Footer navigation">
      <a href="/login">Tracker</a>
      <a href="/app#esports">VCT</a>
      <a href="/app#skins">Skins</a>
      <a href="/comp">Meta Comp</a>
      <a href="/app#overlay">OBS Overlay</a>
    </nav>

