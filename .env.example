# ── ValTracker Environment Variables ──
# Copy this file to .env and fill in your values

# HenrikDev API Key (required)
HENRIKDEV_API_KEY=your_henrikdev_api_key_here

# Supabase (optional — enables persistent caching)
SUPABASE_URL=
SUPABASE_KEY=

# Admin secret for cache management (auto-generated if not set in dev)
ADMIN_SECRET=

# CORS origins (comma-separated)
CORS_ALLOWED_ORIGINS=https://valtracker-frontend.onrender.com,https://valtracker.gg

# Frontend API URL (used by Astro SSR pages like /share/[id])
PUBLIC_API_URL=http://localhost:5000
